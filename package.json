{
	"name": "simple-start",
	"private": true,
	"version": "2.2.0",
	"description": "Highly customizable new tab extension with categorized bookmark groups",
	"type": "module",
	"scripts": {
		"dev:chrome": "wxt",
		"dev": "wxt -b firefox",
		"build:chrome": "wxt build",
		"build": "wxt build -b firefox",
		"zip:chrome": "wxt zip",
		"zip": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prettier:check": "prettier . --check"
	},
	"dependencies": {
		"@hello-pangea/dnd": "18.0.1",
		"@mantine/colors-generator": "9.3.1",
		"@mantine/core": "9.3.1",
		"@mantine/form": "9.3.1",
		"@mantine/hooks": "9.3.1",
		"@mantine/notifications": "9.3.1",
		"@tabler/icons-react": "3.44.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@wxt-dev/module-react": "1.2.2",
		"eslint": "9.39.4",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"postcss": "8.5.15",
		"postcss-preset-mantine": "1.18.0",
		"postcss-simple-vars": "7.0.1",
		"prettier": "3.8.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.0",
		"wxt": "0.20.26"
	}
}
