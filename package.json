{
	"name": "simple-start",
	"private": true,
	"version": "2.2.0",
	"description": "Highly customizable new tab extension with categorized bookmark groups",
	"type": "module",
	"scripts": {
		"dev:chrome": "wxt",
		"dev": "wxt -b firefox",
		"build:chrome": "wxt build",
		"build": "wxt build -b firefox",
		"zip:chrome": "wxt zip",
		"zip": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prettier:check": "prettier . --check"
	},
	"dependencies": {
		"@hello-pangea/dnd": "16.6.0",
		"@mantine/core": "~5.6.3",
		"@mantine/form": "~5.6.3",
		"@mantine/hooks": "~5.6.3",
		"@mantine/notifications": "~5.6.3",
		"@tabler/icons-react": "3.2.0",
		"react": "~18.2.0",
		"react-dom": "~18.2.0",
		"zod": "3.23.0"
	},
	"devDependencies": {
		"@types/react": "~18.0.24",
		"@types/react-dom": "~18.0.8",
		"@wxt-dev/module-react": "1.2.2",
		"typescript": "6.0.3",
		"wxt": "0.20.26",
		"typescript-eslint": "8.60.0",
		"eslint": "9.39.4",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react": "7.35.2",
		"prettier": "3.8.3",
		"eslint-plugin-react-refresh": "0.4.10"
	}
}
